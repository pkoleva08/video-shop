{
  "name": "video-shop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:client": "vite",
    "dev:backend": "cd backend && mvnw.cmd spring-boot:run",
    "dev:all": "concurrently -k -n client,backend -c cyan,green \"npm:dev:client\" \"npm:dev:backend\"",
    "start:backend": "cd backend && mvnw.cmd spring-boot:run",
    "build:frontend": "tsc -b && vite build",
    "build:backend": "cd backend && mvnw.cmd -q -DskipTests package",
    "build": "npm run build:frontend && npm run build:backend",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1"
  }
}
